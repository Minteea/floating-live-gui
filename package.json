{
  "name": "floating-live-gui",
  "productName": "FloatingLiveGUI",
  "version": "0.11.0-beta.4",
  "author": {
    "name": "Minteea",
    "email": "minteea@qq.com"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "keywords": [],
  "private": true,
  "license": "GPLv3",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "chcp 65001 && electron-vite preview",
    "dev": "chcp 65001 && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@floating-live/acfun": "^0.16.11",
    "@floating-live/bilibili": "^0.16.17",
    "@floating-live/plugin-auth": "^0.16.5",
    "@floating-live/plugin-console-event": "^0.16.3",
    "@floating-live/plugin-save": "^0.16.4",
    "@floating-live/snapshot": "^0.16.3",
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.1",
    "@msgpack/msgpack": "^3.1.2",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/react": "^1.1.0",
    "ahooks": "^3.9.7",
    "antd": "^6.3.7",
    "compressing": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.3.9",
    "floating-live": "^0.16.6",
    "hono": "^4.12.18",
    "keytar": "^7.9.0",
    "nanostores": "^1.3.0",
    "node-json-db": "^2.3.0",
    "portfinder": "^1.0.37",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^7.15.0",
    "serialize-error": "^12.0.0",
    "uint8arrays": "^5.1.0",
    "yaml": "^2.1.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "node-abi": "^4.31.0",
    "prettier": "^3.7.4",
    "sass": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
